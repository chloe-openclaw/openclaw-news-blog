---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="text-center py-8">
    <p class="text-xs uppercase tracking-[0.4em] text-neutral-500 mb-4">OpenClaw</p>
    <h1 class="text-3xl md:text-4xl font-semibold text-neutral-50 leading-tight">
      News & Updates
    </h1>
    <p class="mt-3 text-neutral-400 text-sm max-w-md mx-auto">
      Clear, trustworthy updates — from a client perspective.
    </p>
  </section>

  <!-- Section Buttons -->
  <section class="mt-10 grid gap-4 md:grid-cols-2">
    <a href={`${import.meta.env.BASE_URL}/news`}
       class="group flex flex-col justify-between rounded-2xl border border-neutral-800 bg-neutral-900/50 p-8 hover:border-neutral-600 hover:bg-neutral-900/80 transition-all">
      <div>
        <span class="text-xs uppercase tracking-widest text-neutral-500">Blog</span>
        <h2 class="text-xl font-semibold text-neutral-100 mt-2 group-hover:text-white transition-colors">
          Latest News
        </h2>
        <p class="mt-2 text-sm text-neutral-400">Platform updates, releases, and deep dives.</p>
      </div>
      <span class="mt-6 text-neutral-500 group-hover:text-neutral-300 text-sm transition-colors">→</span>
    </a>

    <a href={`${import.meta.env.BASE_URL}/posts/introducing-openclaw`}
       class="group flex flex-col justify-between rounded-2xl border border-neutral-800 bg-neutral-900/50 p-8 hover:border-neutral-600 hover:bg-neutral-900/80 transition-all">
      <div>
        <span class="text-xs uppercase tracking-widest text-neutral-500">Guide</span>
        <h2 class="text-xl font-semibold text-neutral-100 mt-2 group-hover:text-white transition-colors">
          What is OpenClaw?
        </h2>
        <p class="mt-2 text-sm text-neutral-400">Start here. The overview of what we do and why.</p>
      </div>
      <span class="mt-6 text-neutral-500 group-hover:text-neutral-300 text-sm transition-colors">→</span>
    </a>
  </section>

  <!-- 小生物 Section -->
  <section class="mt-14">
    <details class="group rounded-2xl border border-neutral-800 bg-neutral-900/30" id="creatures-section">
      <summary class="cursor-pointer px-6 py-5 flex items-center justify-between text-sm font-medium text-neutral-400 hover:text-neutral-200 transition-colors select-none">
        <span>小生物</span>
        <span class="text-neutral-600 group-open:rotate-90 transition-transform">▸</span>
      </summary>
      <div class="relative w-full overflow-hidden rounded-b-2xl" style="height: 320px;">
        <div id="creature-stage" class="absolute inset-0"></div>
      </div>
    </details>
  </section>

  <script type="module">
    const section = document.getElementById('creatures-section');
    const stage = document.getElementById('creature-stage');
    const names = ['Clancy', 'Gabby', 'Michael', 'Chloe', 'Nick'];
    const colors = ['#7dd3fc', '#f9a8d4', '#a7f3d0', '#facc15', '#84cc16'];
    let creatures = [];
    let animId = null;
    let initialized = false;

    function init() {
      if (initialized) return;
      initialized = true;
      const rect = stage.getBoundingClientRect();
      const w = rect.width;
      const h = rect.height;

      creatures = Array.from({ length: 5 }).map((_, i) => {
        const wrapper = document.createElement('div');
        wrapper.className = 'absolute flex flex-col items-center gap-1';

        const label = document.createElement('div');
        label.className = 'text-[10px] uppercase tracking-[0.2em] text-neutral-400/80';
        label.textContent = names[i];

        const el = document.createElement('div');
        if (names[i] === 'Nick') {
          el.className = 'relative text-2xl leading-none select-none';
          const body = document.createElement('span');
          body.textContent = '🦗';
          const hat = document.createElement('span');
          hat.textContent = '🎩';
          hat.className = 'absolute -top-3 left-1/2 -translate-x-1/2 text-sm';
          hat.style.filter = 'hue-rotate(180deg) brightness(1.5)';
          el.appendChild(body);
          el.appendChild(hat);
          el.style.filter = 'drop-shadow(0 4px 3px rgb(0 0 0 / 0.07))';
        } else {
          el.className = 'h-6 w-6 rounded-full shadow-lg';
          el.style.background = colors[i % colors.length];
        }

        const bubble = document.createElement('div');
        bubble.className = 'absolute -top-8 px-2 py-1 rounded-full text-[10px] bg-neutral-900/80 text-neutral-200 border border-neutral-700 opacity-0 transition-opacity duration-200 whitespace-nowrap';
        bubble.textContent = 'Hola Lin Ch Tin';

        wrapper.appendChild(bubble);
        wrapper.appendChild(el);
        wrapper.appendChild(label);
        stage.appendChild(wrapper);

        return {
          el: wrapper,
          bubble,
          name: names[i],
          x: Math.random() * (w - 40) + 10,
          y: Math.random() * (h - 60) + 10,
          vx: (Math.random() * 0.6 + 0.4) * (Math.random() > 0.5 ? 1 : -1),
          vy: (Math.random() * 0.6 + 0.4) * (Math.random() > 0.5 ? 1 : -1),
          hop: Math.random() * Math.PI * 2,
          speakCooldown: 0,
          jumpTimer: Math.random() * 2000 + 1000,
          isJumping: false,
          jumpProgress: 0,
          jumpStartX: 0, jumpStartY: 0,
          jumpTargetX: 0, jumpTargetY: 0,
        };
      });

      let last = performance.now();
      function tick(now) {
        const dt = Math.min(32, now - last);
        last = now;
        const rect = stage.getBoundingClientRect();
        const w = rect.width;
        const h = rect.height;

        creatures.forEach((c) => {
          if (c.name === 'Nick') {
            if (c.isJumping) {
              c.jumpProgress += dt * 0.003;
              if (c.jumpProgress >= 1) {
                c.isJumping = false;
                c.x = c.jumpTargetX;
                c.y = c.jumpTargetY;
                c.jumpTimer = Math.random() * 2000 + 1000;
              } else {
                const t = c.jumpProgress;
                const ease = 1 - Math.pow(1 - t, 4);
                c.x = c.jumpStartX + (c.jumpTargetX - c.jumpStartX) * ease;
                c.y = c.jumpStartY + (c.jumpTargetY - c.jumpStartY) * ease;
                const jumpScale = 1 + Math.sin(t * Math.PI) * 0.8;
                c.el.style.transform = `translate(${c.x}px, ${c.y}px) scale(${jumpScale})`;
                return;
              }
            } else {
              c.jumpTimer -= dt;
              if (c.jumpTimer <= 0) {
                c.isJumping = true;
                c.jumpProgress = 0;
                c.jumpStartX = c.x;
                c.jumpStartY = c.y;
                c.jumpTargetX = Math.max(10, Math.min(w - 40, c.x + (Math.random() - 0.5) * 300));
                c.jumpTargetY = Math.max(10, Math.min(h - 60, c.y + (Math.random() - 0.5) * 200));
              }
            }
            c.el.style.transform = `translate(${c.x}px, ${c.y}px)`;
          } else {
            c.hop += dt * 0.01;
            c.x += c.vx * dt * 0.04;
            c.y += c.vy * dt * 0.04 + Math.sin(c.hop) * 0.18;
            if (c.x <= 10 || c.x >= w - 40) c.vx *= -1;
            if (c.y <= 10 || c.y >= h - 60) c.vy *= -1;
            c.x = Math.max(10, Math.min(w - 40, c.x));
            c.y = Math.max(10, Math.min(h - 60, c.y));
            if (c.speakCooldown > 0) c.speakCooldown -= dt;
            c.el.style.transform = `translate(${c.x}px, ${c.y}px) scale(${1 + Math.sin(c.hop) * 0.1})`;
          }
        });

        const michael = creatures.find((c) => c.name === 'Michael');
        const clancy = creatures.find((c) => c.name === 'Clancy');
        if (michael && clancy) {
          const dist = Math.hypot(michael.x - clancy.x, michael.y - clancy.y);
          if (dist < 60 && michael.speakCooldown <= 0) {
            michael.bubble.style.opacity = '1';
            michael.speakCooldown = 2000;
            setTimeout(() => { michael.bubble.style.opacity = '0'; }, 1200);
          }
        }

        animId = requestAnimationFrame(tick);
      }
      animId = requestAnimationFrame(tick);
    }

    section.addEventListener('toggle', () => {
      if (section.open) {
        init();
      } else if (animId) {
        cancelAnimationFrame(animId);
        animId = null;
      }
    });
  </script>
</BaseLayout>
