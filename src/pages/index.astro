---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="text-center py-8">
    <p class="text-xs uppercase tracking-[0.4em] text-neutral-500 mb-4">OpenClaw</p>
    <h1 class="text-3xl md:text-4xl font-semibold text-neutral-50 leading-tight">
      News & Updates
    </h1>
    <p class="mt-3 text-neutral-400 text-sm max-w-md mx-auto">
      Clear, trustworthy updates — from a client perspective.
    </p>
  </section>

  <!-- Section Buttons -->
  <section class="mt-10 grid gap-4 md:grid-cols-2">
    <a href={`${import.meta.env.BASE_URL}news`}
       class="group flex flex-col justify-between rounded-2xl border border-neutral-800 bg-neutral-900/50 p-8 hover:border-neutral-600 hover:bg-neutral-900/80 transition-all">
      <div>
        <span class="text-xs uppercase tracking-widest text-neutral-500">Blog</span>
        <h2 class="text-xl font-semibold text-neutral-100 mt-2 group-hover:text-white transition-colors">
          Latest News
        </h2>
        <p class="mt-2 text-sm text-neutral-400">Platform updates, releases, and deep dives.</p>
      </div>
      <span class="mt-6 text-neutral-500 group-hover:text-neutral-300 text-sm transition-colors">→</span>
    </a>

    <a href={`${import.meta.env.BASE_URL}posts/introducing-openclaw`}
       class="group flex flex-col justify-between rounded-2xl border border-neutral-800 bg-neutral-900/50 p-8 hover:border-neutral-600 hover:bg-neutral-900/80 transition-all">
      <div>
        <span class="text-xs uppercase tracking-widest text-neutral-500">Guide</span>
        <h2 class="text-xl font-semibold text-neutral-100 mt-2 group-hover:text-white transition-colors">
          What is OpenClaw?
        </h2>
        <p class="mt-2 text-sm text-neutral-400">Start here. The overview of what we do and why.</p>
      </div>
      <span class="mt-6 text-neutral-500 group-hover:text-neutral-300 text-sm transition-colors">→</span>
    </a>
  </section>

  <!-- 小生物 Section (collapsed details) -->
  <section class="mt-14">
    <details class="group rounded-2xl border border-neutral-800 bg-neutral-900/30">
      <summary class="cursor-pointer px-6 py-5 flex items-center justify-between text-sm font-medium text-neutral-400 hover:text-neutral-200 transition-colors select-none">
        <span>Our Principles</span>
        <span class="text-neutral-600 group-open:rotate-90 transition-transform">▸</span>
      </summary>
      <div class="px-6 pb-6 grid gap-4 md:grid-cols-3">
        <div class="rounded-xl bg-neutral-900/60 border border-neutral-800/50 p-5">
          <h3 class="text-sm font-semibold text-neutral-200">Reliability First</h3>
          <p class="mt-2 text-xs text-neutral-500 leading-relaxed">Every change ships with guardrails, monitoring, and rollback plans.</p>
        </div>
        <div class="rounded-xl bg-neutral-900/60 border border-neutral-800/50 p-5">
          <h3 class="text-sm font-semibold text-neutral-200">Cost Clarity</h3>
          <p class="mt-2 text-xs text-neutral-500 leading-relaxed">Usage and spend tracked transparently with proactive alerts.</p>
        </div>
        <div class="rounded-xl bg-neutral-900/60 border border-neutral-800/50 p-5">
          <h3 class="text-sm font-semibold text-neutral-200">Human‑Readable</h3>
          <p class="mt-2 text-xs text-neutral-500 leading-relaxed">Updates written for people first, while staying bot‑friendly.</p>
        </div>
      </div>
    </details>
  </section>
</BaseLayout>
